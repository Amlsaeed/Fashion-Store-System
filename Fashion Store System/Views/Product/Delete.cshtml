@model Fashion_Store_System.Models.Product

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <title>تأكيد الحذف - @Model.Name</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.rtl.min.css">
    <style>
        body {
            background-color: #F8EDED;
            font-family: 'Segoe UI', sans-serif;
            height: 100vh;
            display: flex;
            align-items: center;
        }

        .delete-card {
            background: white;
            border-radius: 20px;
            padding: 40px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            max-width: 500px;
            margin: auto;
            text-align: center;
            border: 2px solid #ff000021;
        }

        .product-preview-img {
            width: 120px;
            height: 120px;
            object-fit: cover;
            border-radius: 15px;
            margin-bottom: 20px;
            border: 3px solid #eee;
        }

        .btn-confirm {
            background-color: #d33;
            color: white;
            border-radius: 50px;
            padding: 10px 40px;
            font-weight: 600;
            border: none;
        }

        .btn-cancel {
            background-color: #6c757d;
            color: white;
            border-radius: 50px;
            padding: 10px 40px;
            font-weight: 600;
            text-decoration: none;
        }
    </style>
</head>
<body>

    <div class="container text-center">
        <div class="delete-card">
            <h3 class="text-danger fw-bold mb-4">تأكيد حذف المنتج</h3>

            <img src="@Model.ImageUrl" class="product-preview-img" onerror="this.src='/Images/default-product.png'">

            <h4 class="mb-2">@Model.Name</h4>
            <p class="text-muted mb-4">هل أنتِ متأكدة من حذف هذا المنتج نهائياً من المخزن؟ لا يمكن التراجع عن هذا الإجراء.</p>

            <form asp-action="Delete">
                <input type="hidden" asp-for="Id" />

                <div class="d-flex justify-content-center gap-3">
                    <button type="submit" class="btn btn-confirm shadow">نعم، احذف</button>
                    <a asp-action="Index" class="btn btn-cancel shadow">إلغاء</a>
                </div>
            </form>
        </div>
    </div>

</body>
</html>