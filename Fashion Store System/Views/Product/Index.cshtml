@model IEnumerable<Fashion_Store_System.ViewModels.ProductVM.ProductVMDt>
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <title>إدارة المنتجات</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.rtl.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.bootstrap5.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        body {
            background-color: #f8f9fa;
            font-family: 'Segoe UI', sans-serif;
            padding: 20px;
            direction: rtl;
        }

        .stat-card {
            border: none;
            border-radius: 15px;
            transition: 0.3s;
            cursor: pointer;
        }

            .stat-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 10px 20px rgba(0,0,0,0.1);
            }

        .main-card {
            background: white;
            border-radius: 20px;
            padding: 25px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.05);
        }

        /* تثبيت حجم الصورة عشان الجدول ميرتعش */
        .product-img {
            width: 50px !important;
            height: 50px !important;
            object-fit: cover;
            border-radius: 8px;
            background: #eee;
        }

        table.dataTable {
            border-collapse: collapse !important;
            width: 100% !important;
        }

            table.dataTable thead th, table.dataTable tbody td {
                text-align: center !important;
                vertical-align: middle !important;
            }

        .dt-buttons {
            margin-bottom: 15px;
            gap: 8px;
            display: flex;
        }
    </style>
</head>
<body>

    <div class="container-fluid">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold">لوحة تحكم المنتجات</h2>
            <a asp-action="Create" class="btn btn-dark rounded-pill px-4"><i class="bi bi-plus-lg"></i> إضافة منتج</a>
        </div>

        <div class="row mb-4 g-3">
            <div class="col-md-3" onclick="resetFilter()" title="عرض الكل">
                <div class="card stat-card bg-dark text-white p-3">
                    <h6>إجمالي الأصناف</h6>
                    <h2 class="fw-bold">@ViewBag.TotalProducts</h2>
                </div>
            </div>
            <div class="col-md-3" onclick="filterLowStock()" title="اضغط لفلترة النواقص">
                <div class="card stat-card bg-danger text-white p-3">
                    <h6>النواقص (أقل من 5)</h6>
                    <h2 class="fw-bold">@ViewBag.LowStockCount</h2>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card stat-card bg-primary text-white p-3">
                    <h6>إجمالي القطع</h6>
                    <h2 class="fw-bold">@ViewBag.TotalQuantity</h2>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card stat-card bg-success text-white p-3">
                    <h6>قيمة المخزن</h6>
                    <h2 class="fw-bold">@ViewBag.TotalValue.ToString("N0")</h2>
                </div>
            </div>
        </div>

        <div class="main-card">
            <table id="productsTable" class="table table-hover w-100">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>الصورة</th>
                        <th>المنتج</th>
                        <th>القسم</th>
                        <th>السعر</th>
                        <th>الكمية</th>
                        <th>الخصم</th>
                        <th>الحالة</th>
                        <th>العمليات</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>#@item.Id</td>
                            <td>
                                <img src="@Url.Content("~/images/Products/" + item.ImageUrl)"
                                     class="product-img"
                                     onerror="this.src='/images/default.png'; this.onerror=null;"
                                     alt="product">
                            </td>
                            <td class="fw-bold">@item.Name</td>
                            <td><span class="badge bg-light text-dark border">@item.CategoryName</span></td>
                            <td class="text-success fw-bold">@item.Price.ToString("N0")</td>
                            <td class="stock-cell">
                                <span style="color: @(item.Quantity <= 5 ? "#d9534f" : "inherit"); font-weight: @(item.Quantity <= 5 ? "bold" : "normal")">
                                    @item.Quantity
                                </span>
                            </td>
@*                             <td class="stock-cell">@item.Quantity</td>
 *@                            <td>@(item.Discount > 0 ? item.Discount + "%" : "-")</td>
                            <td>
                                <span class="badge @(item.IsActive ? "bg-success-subtle text-success" : "bg-danger-subtle text-danger")">
                                    @(item.IsActive ? "نشط" : "مخفي")
                                </span>
                            </td>
                            <td>
                           

                                <div class="d-flex gap-2 justify-content-center">
                                    @* زرار التفاصيل - اللي هيعرض المقاسات والألوان *@
                                    <a asp-controller="Product" asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info border-0" title="تفاصيل المنتج">
                                        <i class="bi bi-eye-fill"></i>
                                    </a>

                                    @* زرار التعديل *@
                                    <a asp-controller="Product" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary border-0" title="تعديل">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>

                                    @* زرار الحذف *@
                                    <button onclick="deleteProduct(@item.Id)" class="btn btn-sm btn-outline-danger border-0" title="حذف">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.bootstrap5.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.print.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        var table;
        $(document).ready(function() {
            table = $('#productsTable').DataTable({
                language: { url: '//cdn.datatables.net/plug-ins/1.13.6/i18n/ar.json' },
                dom: 'Bfrtip',
                autoWidth: false,
                buttons: [
                    { extend: 'excel', text: 'تصدير Excel', className: 'btn btn-success btn-sm rounded-pill' },
                    { extend: 'print', text: 'طباعة', className: 'btn btn-dark btn-sm rounded-pill' }
                ],
                columnDefs: [{ targets: "_all", className: "dt-center" }]
            });
        });

        // فلترة النواقص: بيفحص عمود الكمية (رقم 5) برمجياً
        function filterLowStock() {
            // مسح أي فلتر قديم أولاً
            $.fn.dataTable.ext.search = [];

            $.fn.dataTable.ext.search.push(
                function(settings, data, dataIndex) {
                    var quantity = parseFloat(data[5]) || 0;
                    return quantity <= 5;
                }
            );
            table.draw();
            // مسح الـ Custom search عشان ميأثرش على البحث العادي بعد الرسم
            $.fn.dataTable.ext.search = [];
        }

        function resetFilter() {
            $.fn.dataTable.ext.search = [];
            table.search('').columns().search('').draw();
        }

        function deleteProduct(id) {
            Swal.fire({
                title: 'تأكيد الحذف',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                confirmButtonText: 'نعم، احذف'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('/Product/Delete/' + id, function (data) {
                        if (data.success) { location.reload(); }
                    });
                }
            });
        }
    </script>
</body>
</html>