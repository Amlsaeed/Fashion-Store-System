@model Fashion_Store_System.Models.Product

@{
    Layout = null; // أو Layout = "_Layout"; حسب نظام مشروعك
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>تفاصيل المنتج | @Model.Name</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.rtl.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

    <style>
        :root {
            --primary-dark: #40415A;
            --soft-bg: #F8EDED;
            --accent-muted-red: #d9534f;
            --accent-green: #27ae60;
            --text-muted: #7f8c8d;
        }

        body {
            background-color: var(--soft-bg);
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            color: var(--primary-dark);
            padding: 40px 0;
        }

        .product-container {
            background: #fff;
            border-radius: 25px;
            box-shadow: 0 15px 50px rgba(0,0,0,0.08);
            overflow: hidden;
            border: none;
        }

        /* الجزء الخاص بالصورة */
        .image-wrapper {
            background-color: #fcfcfc;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .product-main-img {
            max-width: 100%;
            height: auto;
            border-radius: 15px;
            transition: transform 0.3s ease;
        }

            .product-main-img:hover {
                transform: scale(1.02);
            }

        /* تفاصيل المحتوى */
        .content-section {
            padding: 40px;
            border-right: 1px solid #f0f0f0;
        }

        .category-badge {
            background: #eeeef6;
            color: var(--primary-dark);
            padding: 5px 15px;
            border-radius: 50px;
            font-size: 0.9rem;
            font-weight: 500;
        }

        .price-container {
            margin: 20px 0;
        }

        .current-price {
            font-size: 2.5rem;
            font-weight: 800;
            color: var(--accent-green);
        }

        .old-price {
            text-decoration: line-through;
            color: var(--text-muted);
            font-size: 1.2rem;
            margin-left: 10px;
        }

        /* جدول المقاسات والألوان */
        .variants-card {
            background: #fafafa;
            border-radius: 15px;
            padding: 20px;
            border: 1px solid #eee;
        }

        .table thead {
            background-color: var(--primary-dark);
            color: white;
        }

        .stock-dot {
            height: 10px;
            width: 10px;
            border-radius: 50%;
            display: inline-block;
            margin-left: 5px;
        }

        .btn-action {
            border-radius: 50px;
            padding: 12px 30px;
            font-weight: 600;
            transition: all 0.3s;
        }

        .btn-edit {
            background-color: var(--primary-dark);
            color: white;
        }

            .btn-edit:hover {
                background-color: #2d2e40;
                color: white;
                transform: translateY(-2px);
            }
    </style>
</head>
<body>

    <div class="container">
        <div class="product-container row g-0">

            <div class="col-lg-5 image-wrapper text-center">
                <div class="position-relative">
                    <img src="/images/Products/@Model.ImageUrl"
                         class="product-main-img shadow-sm"
                         alt="@Model.Name"
                         onerror="this.src='/images/default.png'">

                    @if (Model.Discount > 0)
                    {
                        <span class="badge bg-danger position-absolute top-0 start-0 m-3 px-3 py-2 shadow" style="border-radius: 15px;">
                            خصم @Model.Discount%
                        </span>
                    }
                </div>
            </div>

            <div class="col-lg-7 content-section">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <span class="category-badge">
                        <i class="bi bi-tag-fill me-1"></i> @(Model.Category?.Name ?? "بدون قسم")
                    </span>
                    <span class="badge @(Model.IsActive ? "bg-success" : "bg-secondary") rounded-pill px-3">
                        @(Model.IsActive ? "نشط في المتجر" : "مخفي")
                    </span>
                </div>

                <h1 class="fw-bold mb-3">@Model.Name</h1>
                <p class="text-muted fs-5 mb-4">@Model.Description</p>

                <div class="price-container">
                    @if (Model.Discount > 0)
                    {
                        <span class="old-price">@Model.Price.ToString("N0") ج.م</span>
                        <span class="current-price">@((Model.Price - (Model.Price * Model.Discount / 100)).ToString("N0")) <small class="fs-6">ج.م</small></span>
                    }
                    else
                    {
                        <span class="current-price">@Model.Price.ToString("N0") <small class="fs-6">ج.م</small></span>
                    }
                </div>

                <hr class="my-4" style="opacity: 0.1;">

                <div class="variants-card mb-4">
                    <h5 class="fw-bold mb-3"><i class="bi bi-box-seam me-2"></i> توزيع الكميات في المخزن</h5>
                    <div class="table-responsive">
                        <table class="table table-hover text-center align-middle">
                            <thead>
                                <tr>
                                    <th>اللون</th>
                                    <th>المقاس</th>
                                    <th>الرصيد</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Variants != null && Model.Variants.Any())
                                {
                                    foreach (var v in Model.Variants)
                                    {
                                        <tr>
                                            <td>
                                                <span class="border px-3 py-1 rounded-pill bg-white shadow-sm">
                                                    <i class="bi bi-palette-fill me-1" style="color: var(--primary-dark);"></i>
                                                    @v.ProductColor?.Name
                                                </span>
                                            </td>
                                            <td><span class="fw-bold text-secondary">@v.ProductSize?.Name</span></td>
                                            <td>
                                                @if (v.Quantity > 5)
                                                {
                                                    <span class="text-success fw-bold">
                                                        <span class="stock-dot bg-success"></span> @v.Quantity قطعة
                                                    </span>
                                                }
                                                else if (v.Quantity > 0)
                                                {
                                                    <span style="color: #f0ad4e;" class="fw-bold">
                                                        <span class="stock-dot" style="background-color: #f0ad4e;"></span> @v.Quantity (قارب على النفاذ)
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span style="color: var(--accent-muted-red);" class="fw-bold">
                                                        <span class="stock-dot" style="background-color: var(--accent-muted-red);"></span> نفذ تماماً
                                                    </span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="3" class="py-4 text-muted">لا توجد تفاصيل لهذا المنتج حالياً</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="d-flex gap-3 mt-auto">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-edit btn-action shadow-sm">
                        <i class="bi bi-pencil-square me-1"></i> تعديل بيانات المنتج
                    </a>
                    <a asp-action="Index" class="btn btn-outline-secondary btn-action">
                        <i class="bi bi-arrow-right me-1"></i> العودة للمخزن
                    </a>
                </div>
            </div>
        </div>
    </div>

    <footer class="text-center mt-5 text-muted small">
        &copy; @DateTime.Now.Year - Fashion Store System | إدارة المخزون الذكية
    </footer>

</body>
</html>