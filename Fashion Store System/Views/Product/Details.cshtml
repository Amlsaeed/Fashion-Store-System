@model Fashion_Store_System.Models.Product

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <title>تفاصيل المنتج - @Model.Name</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.rtl.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        :root {
            --side-bg: #40415A;
            --pale-bg: #F8EDED;
        }

        body {
            background-color: var(--pale-bg);
            padding: 50px 0;
            font-family: 'Segoe UI', sans-serif;
        }

        .details-card {
            background: white;
            border-radius: 25px;
            overflow: hidden;
            box-shadow: 0 15px 40px rgba(0,0,0,0.1);
            border: none;
        }

        .product-img {
            width: 100%;
            height: 500px;
            object-fit: cover;
        }

        .info-section {
            padding: 40px;
        }

        .price-tag {
            font-size: 2.5rem;
            color: #27ae60;
            font-weight: 800;
        }

        .old-price {
            text-decoration: line-through;
            color: #999;
            font-size: 1.2rem;
        }

        .badge-custom {
            padding: 10px 20px;
            border-radius: 50px;
            font-size: 0.9rem;
        }
    </style>
</head>
<body>

    <div class="container">
        <div class="details-card row g-0">
            <div class="col-md-5">
                <img src="@Model.ImageUrl" class="product-img" onerror="this.src='/Images/default-product.png'">
            </div>

            <div class="col-md-7 info-section">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <span class="badge bg-dark badge-custom">@Model.Category?.Name</span>
                    <span class="badge @(Model.IsActive ? "bg-success" : "bg-danger") badge-custom">
                        @(Model.IsActive ? "نشط بالموقع" : "مخفي")
                    </span>
                </div>

                <h1 class="display-5 fw-bold mb-3" style="color: var(--side-bg);">@Model.Name</h1>
                <p class="text-muted fs-5 mb-4">@Model.Description</p>

                <div class="mb-4">
                    @if (Model.Discount > 0)
                    {
                        <span class="old-price">@Model.Price.ToString("N0") ج.م</span>
                        <span class="badge bg-danger ms-2">خصم @Model.Discount%</span>
                        <div class="price-tag">@((Model.Price - (Model.Price * Model.Discount / 100)).ToString("N0")) ج.م</div>
                    }
                    else
                    {
                        <div class="price-tag">@Model.Price.ToString("N0") ج.م</div>
                    }
                </div>

                <div class="row bg-light p-3 rounded-4 mb-4">
                    <div class="col-6">
                        <small class="text-muted d-block">الكمية المتاحة</small>
                        <span class="fw-bold fs-4 @(Model.Quantity <= 5 ? "text-danger" : "")">@Model.Quantity قطع</span>
                    </div>
                    <div class="col-6 border-start">
                        <small class="text-muted d-block">تاريخ الإضافة</small>
                        <span class="fw-bold fs-5">@Model.CreatedAt.ToShortDateString()</span>
                    </div>
                </div>

                <div class="d-flex gap-3 mt-5">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-dark btn-lg px-5 shadow-sm" style="border-radius: 50px;">
                        <i class="bi bi-pencil-square me-2"></i> تعديل المنتج
                    </a>
                    <a asp-action="Index" class="btn btn-outline-secondary btn-lg px-5" style="border-radius: 50px;">
                        عودة للجدول
                    </a>
                </div>
            </div>
        </div>
    </div>

</body>
</html>