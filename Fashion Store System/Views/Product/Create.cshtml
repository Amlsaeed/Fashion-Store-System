@model Fashion_Store_System.ViewModels.ProductVM.ProductVM
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <title>إضافة منتج متطور</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.rtl.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        body {
            background: #F8EDED;
            padding: 20px;
            font-family: 'Segoe UI';
        }

        .form-card {
            background: white;
            border-radius: 20px;
            padding: 30px;
            max-width: 1100px;
            margin: auto;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        }

        .section-title {
            color: #d63384;
            font-weight: bold;
            border-bottom: 2px solid #eee;
            padding-bottom: 10px;
            margin-bottom: 15px;
        }

        .variant-table-container {
            display: none;
            margin-top: 25px;
        }

        /* حل مشكلة الـ keyframes - نضع علامة @@ مرتين */
        @@keyframes fadeIn {
            from {
                opacity: 0;
            }

            to {
                opacity: 1;
            }
        }

        .animate-fade {
            animation: fadeIn 0.5s;
        }

        /* تنسيق السويتش ليناسب ذوقك الـ Luxury */
        .custom-switch .form-check-input {
            width: 3em;
            height: 1.5em;
            cursor: pointer;
        }

            .custom-switch .form-check-input:checked {
                background-color: #27ae60; /* اللون الأخضر لو شغال */
                border-color: #27ae60;
            }

            .custom-switch .form-check-input:not(:checked) {
                background-color: #d9534f; /* اللون الأحمر الهادي لو مش شغال */
                border-color: #d9534f;
            }
    </style>
</head>
<body>

    <div class="form-card">
        <h3 class="mb-4 text-center">إضافة منتج وتحديد المخزون</h3>
        <form asp-action="Create" method="post" enctype="multipart/form-data">

            <div class="row">
                <div class="col-md-8">
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-bold">اسم المنتج</label>
                        <input asp-for="Name" class="form-control" required>
                    </div>
                    <div class="row">
                        <div class="col-6 mb-3">
                            <label asp-for="Price" class="fw-bold">السعر</label>
                            <input asp-for="Price" class="form-control">
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="Discount" class="fw-bold">الخصم (%)</label>
                            <input asp-for="Discount" class="form-control" type="number" min="0" max="100" placeholder="0">
@*                             <small class="text-muted" style="font-size: 0.8rem;">اتركها 0 إذا لا يوجد خصم</small>
 *@                        </div>
                        <div class="col-6 mb-3">
                            <label class="fw-bold">القسم</label>
                            <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.CategoryList"></select>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-bold">الوصف</label>
                        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="fw-bold d-block mb-2">حالة المنتج</label>
                        <div class="form-check form-switch custom-switch">
                            <input class="form-check-input" type="checkbox" asp-for="IsActive" id="IsActiveSwitch" checked>
                            <label class="form-check-label ms-2" for="IsActiveSwitch" id="statusLabel">المنتج نشط (سيظهر للعملاء)</label>
                        </div>
                    </div>
                </div>
                <div class="col-md-4 text-center">
                    <label class="fw-bold">صورة المنتج</label>
                    <div class="border rounded p-2 bg-light mb-2" style="height: 220px; display: flex; align-items: center; justify-content: center; overflow: hidden;">
                        <img id="imgPreview" style="max-height: 100%; max-width: 100%; display: none;">
                        <i class="bi bi-camera fs-1 text-muted" id="camIcon"></i>
                    </div>
                    <input asp-for="ImageFile" type="file" class="form-control" id="fileInput">
                </div>
            </div>

            <hr class="my-4">

            <div class="row">
                <div class="col-md-6 border-end">
                    <h5 class="section-title"><i class="bi bi-palette me-2"></i>الألوان المختارة</h5>
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var item in (SelectList)ViewBag.ColorList)
                        {
                            <div class="form-check border p-2 rounded bg-light">
                                <input class="form-check-input color-check" type="checkbox" value="@item.Value" data-name="@item.Text" id="c_@item.Value">
                                <label class="form-check-label px-2" for="c_@item.Value">@item.Text</label>
                            </div>
                        }
                    </div>
                </div>
                <div class="col-md-6 ps-4">
                    <h5 class="section-title"><i class="bi bi-rulers me-2"></i>المقاسات المختارة</h5>
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var item in (SelectList)ViewBag.SizeList)
                        {
                            <div class="form-check border p-2 rounded bg-light">
                                <input class="form-check-input size-check" type="checkbox" value="@item.Value" data-name="@item.Text" id="s_@item.Value">
                                <label class="form-check-label px-2" for="s_@item.Value">@item.Text</label>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="variant-table-container animate-fade" id="tableContainer">
                <h5 class="section-title text-primary mt-4"><i class="bi bi-box-seam me-2"></i>توزيع المخزون (الكميات)</h5>
                <table class="table table-hover border">
                    <thead class="table-light">
                        <tr>
                            <th>اللون</th>
                            <th>المقاس</th>
                            <th style="width: 150px;">الكمية</th>
                        </tr>
                    </thead>
                    <tbody id="variantBody"></tbody>
                </table>
            </div>

            <div class="mt-5">
                <button type="submit" class="btn btn-dark w-100 py-3 rounded-pill fw-bold shadow-sm">
                    <i class="bi bi-check2-all me-2"></i> تأكيد وحفظ المنتج
                </button>
            </div>
        </form>
    </div>

    <script>
        const colorChecks = document.querySelectorAll('.color-check');
        const sizeChecks = document.querySelectorAll('.size-check');
        const variantBody = document.getElementById('variantBody');
        const tableContainer = document.getElementById('tableContainer');

        function generateVariants() {
            variantBody.innerHTML = '';
            let combinations = 0;

            colorChecks.forEach(color => {
                if (color.checked) {
                    sizeChecks.forEach(size => {
                        if (size.checked) {
                            combinations++;
                            const colorName = color.getAttribute('data-name');
                            const sizeName = size.getAttribute('data-name');

                            const row = `
                                <tr>
                                    <td><span class="badge bg-outline-dark border text-dark p-2">${colorName}</span></td>
                                    <td><span class="badge bg-secondary p-2">${sizeName}</span></td>
                                    <td>
                                        <input type="number" name="VariantQuantities" class="form-control" value="1" min="0">
                                        <input type="hidden" name="VariantColors" value="${color.value}">
                                        <input type="hidden" name="VariantSizes" value="${size.value}">
                                    </td>
                                </tr>`;
                            variantBody.insertAdjacentHTML('beforeend', row);
                        }
                    });
                }
            });
            tableContainer.style.display = combinations > 0 ? 'block' : 'none';
        }

        colorChecks.forEach(c => c.addEventListener('change', generateVariants));
        sizeChecks.forEach(s => s.addEventListener('change', generateVariants));

        document.getElementById('fileInput').onchange = e => {
            const [file] = e.target.files;
            if (file) {
                const preview = document.getElementById('imgPreview');
                preview.src = URL.createObjectURL(file);
                preview.style.display = 'block';
                document.getElementById('camIcon').style.display = 'none';
            }
        }
            document.getElementById('IsActiveSwitch').addEventListener('change', function() {
            const label = document.getElementById('statusLabel');
            if(this.checked) {
                label.innerText = "المنتج نشط (سيظهر للعملاء)";
                label.style.color = "#27ae60";
            } else {
                label.innerText = "المنتج غير نشط (سيتم إخفاؤه)";
                label.style.color = "#d9534f";
            }
        });
    </script>
</body>
</html>