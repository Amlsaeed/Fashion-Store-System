@model Fashion_Store_System.ViewModels.ProductVM.ProductVM
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.rtl.min.css">
    <style>
        body {
            background: #F8EDED;
            padding: 40px;
        }

        .form-card {
            background: white;
            border-radius: 20px;
            padding: 30px;
            max-width: 900px;
            margin: auto;
        }

        .preview-box {
            width: 100%;
            height: 250px;
            border: 2px dashed #ccc;
            border-radius: 15px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

            .preview-box img {
                max-height: 100%;
                max-width: 100%;
                display: none;
            }
    </style>
</head>
<body>
    <div class="form-card">
        <h3 class="mb-4 text-center">إضافة منتج جديد</h3>
        <form asp-action="Create" method="post" enctype="multipart/form-data">
            <div class="row">
                <div class="col-md-8">
                    <div class="mb-3"><label>اسم المنتج</label><input asp-for="Name" class="form-control"></div>
                    <div class="mb-3"><label>الوصف</label><textarea asp-for="Description" class="form-control"></textarea></div>
                    <div class="row">
                        <div class="col-6 mb-3"><label>السعر</label><input asp-for="Price" class="form-control"></div>
                        <div class="col-6 mb-3"><label>الخصم %</label><input asp-for="Discount" class="form-control"></div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="preview-box" id="pBox"><i class="bi bi-image" id="pIcon"></i><img id="pImg"></div>
                    <input asp-for="ImageFile" type="file" class="form-control mt-2" id="iInp">
                    <div class="mt-3"><label>القسم</label><select asp-for="CategoryId" class="form-select" asp-items="ViewBag.CategoryList"></select></div>
                    <div class="mt-3"><label>الكمية</label><input asp-for="Quantity" class="form-control"></div>
                </div>
            </div>
            <button type="submit" class="btn btn-dark w-100 mt-4">حفظ المنتج</button>
        </form>
    </div>
    <script>
        iInp.onchange = e => {
            const [f] = iInp.files;
            if(f){ pImg.src = URL.createObjectURL(f); pImg.style.display='block'; pIcon.style.display='none'; }
        }
    </script>
</body>
</html>