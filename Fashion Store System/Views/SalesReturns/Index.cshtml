@model IEnumerable<Fashion_Store_System.Models.SalesReturn>
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.rtl.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        body {
            background: #FFF5E1;
            padding: 20px;
            font-family: 'Segoe UI';
        }

        .return-card {
            background: white;
            border-radius: 15px;
            padding: 20px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.05);
            border-top: 5px solid #FF8C00;
        }

        .btn-return {
            background: #FF8C00;
            color: white;
            border-radius: 50px;
        }

            .btn-return:hover {
                background: #E67E00;
                color: white;
            }
    </style>
</head>
<body>
    <div class="container mt-4">
        <div class="d-flex justify-content-between mb-4">
            <h2 class="fw-bold" style="color: #FF8C00;"><i class="bi bi-arrow-counterclockwise"></i> سجل مرتجع المبيعات</h2>
            <a asp-action="Create" class="btn btn-return px-4">إضافة مرتجع جديد</a>
        </div>

        <div class="return-card">
            <table class="table table-hover text-center">
                <thead class="table-light">
                    <tr>
                        <th>رقم المرتجع</th>
                        <th>رقم الفاتورة الأصلية</th>
                        <th>التاريخ</th>
                        <th>المبلغ المسترد</th>
                        <th>العمليات</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>#@item.Id</td>
                            <td>#@item.SalesInvoiceId</td>
                            <td>@item.ReturnDate.ToShortDateString()</td>
                            <td class="fw-bold text-danger">@item.TotalRefundAmount.ToString("N0") ج.م</td>
                            <td>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning"><i class="bi bi-eye"></i></a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</body>
</html>
