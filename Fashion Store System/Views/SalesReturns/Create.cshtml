@model Fashion_Store_System.Models.SalesReturn
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.rtl.min.css">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <style>
        body {
            background: #FFF5E1;
            padding: 30px;
        }

        .create-card {
            background: white;
            border-radius: 20px;
            padding: 30px;
            border-top: 8px solid #FF8C00;
        }

        .refund-total {
            background: #FF8C00;
            color: white;
            padding: 10px 20px;
            border-radius: 10px;
            font-weight: bold;
        }
    </style>
</head>
<body>
    <div class="container create-card shadow">
        <h3 class="fw-bold mb-4" style="color: #FF8C00;">مرتجع مبيعات ذكي (بالبحث)</h3>

        <div class="row mb-4">
            <div class="col-md-5">
                <label class="fw-bold">ادخلي رقم فاتورة البيع الأصلية:</label>
                <div class="input-group">
                    <input type="number" id="invoiceIdInput" class="form-control" placeholder="مثلاً: 10">
                    <button type="button" class="btn btn-warning fw-bold" onclick="loadInvoice()">بحث عن الأصناف</button>
                </div>
            </div>
        </div>

        <form asp-action="Create" id="returnForm">
            <input type="hidden" asp-for="SalesInvoiceId" id="hiddenInvoiceId" />

            <table class="table table-bordered" id="itemsTable">
                <thead class="bg-dark text-white text-center">
                    <tr>
                        <th>المنتج</th>
                        <th>الكمية المباعة</th>
                        <th>كمية المرتجع</th>
                        <th>سعر البيع</th>
                        <th>الإجمالي</th>
                    </tr>
                </thead>
                <tbody class="text-center">
                </tbody>
            </table>

            <div class="d-flex justify-content-between align-items-center mt-4">
                <div class="refund-total">إجمالي المبلغ المسترد: <span id="grandTotal">0</span> ج.م</div>
                <div>
                    <a asp-action="Index" class="btn btn-light rounded-pill px-4">إلغاء</a>
                    <button type="submit" class="btn btn-warning px-5 rounded-pill fw-bold" style="background: #FF8C00; color:white;">تأكيد وحفظ المرتجع</button>
                </div>
            </div>
        </form>
    </div>

    <script>
        function loadInvoice() {
            let id = $('#invoiceIdInput').val();
            if (!id) return alert("يرجى إدخال رقم الفاتورة");

            $.get('/SalesReturns/GetInvoiceDetails?invoiceId=' + id, function (data) {
                if (!data || data.length == 0) {
                    alert("عذراً، هذه الفاتورة غير موجودة أو فارغة!");
                    return;
                }

                $('#hiddenInvoiceId').val(id);
                let rows = '';
                data.forEach((item, i) => {
                    rows += `
                        <tr>
                            <td>
                                <input type="hidden" name="Items[${i}].ProductId" value="${item.productId}">
                                <strong>${item.productName}</strong>
                            </td>
                            <td class="text-muted">${item.quantitySold}</td>
                            <td>
                                <input type="number" name="Items[${i}].Quantity"
                                       class="form-control qty-input mx-auto" style="width:100px"
                                       max="${item.quantitySold}" min="0" value="0"
                                       oninput="updateRowTotal(this, ${item.unitPrice})">
                            </td>
                            <td>
                                <input type="hidden" name="Items[${i}].UnitPrice" value="${item.unitPrice}">
                                ${item.unitPrice} ج.م
                            </td>
                            <td><span class="row-total text-danger fw-bold">0</span> ج.م</td>
                        </tr>`;
                });
                $('#itemsTable tbody').html(rows);
            });
        }

        function updateRowTotal(input, price) {
            let qty = $(input).val() || 0;
            let max = parseInt($(input).attr('max'));

            if (qty > max) {
                alert("خطأ: لا يمكن إرجاع كمية أكبر من المباعة (" + max + ")");
                $(input).val(max);
                qty = max;
            }

            let total = qty * price;
            $(input).closest('tr').find('.row-total').text(total.toLocaleString());

            updateGrandTotal();
        }

        function updateGrandTotal() {
            let total = 0;
            $('.row-total').each(function() {
                total += parseFloat($(this).text().replace(/,/g, '')) || 0;
            });
            $('#grandTotal').text(total.toLocaleString());
        }
    </script>
</body>
</html>