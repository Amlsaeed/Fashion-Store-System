@model Fashion_Store_System.Models.PurchaseInvoice
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.rtl.min.css">
    <style>
        body {
            background: #F8EDED;
            padding: 40px;
        }

        .edit-card {
            background: white;
            border-radius: 20px;
            padding: 30px;
        }
    </style>
</head>
<body>
    <div class="container edit-card shadow">
        <h3 class="fw-bold mb-4">تعديل فاتورة مشتريات #@Model.Id</h3>
        <form asp-action="Edit">
            <input type="hidden" asp-for="Id" />
            <div class="row mb-3">
                <div class="col-md-6">
                    <label>المورد</label>
                    <select asp-for="SupplierId" class="form-select" asp-items="@(new SelectList(ViewBag.Suppliers, "Id", "Name"))"></select>
                </div>
            </div>

            <table class="table table-bordered" id="itemsTable">
                <thead class="bg-dark text-white">
                    <tr>
                        <th>المنتج</th>
                        <th>الكمية</th>
                        <th>السعر</th>
                        <th>حذف</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < Model.PurchaseItems.Count; i++)
                    {
                        <tr id="row-@i">
                            <td>
                                <select name="Items[@i].ProductId" class="form-select">
                                    @foreach (var p in ViewBag.Products)
                                    {
                                        <option value="@p.Id" selected="@(p.Id == Model.PurchaseItems.ElementAt(i).ProductId)">@p.Name</option>
                                    }
                                </select>
                            </td>
                            <td><input type="number" name="Items[@i].Quantity" class="form-control" value="@Model.PurchaseItems.ElementAt(i).Quantity"></td>
                            <td><input type="number" name="Items[@i].UnitPrice" class="form-control" value="@Model.PurchaseItems.ElementAt(i).UnitPrice"></td>
                            <td><button type="button" class="btn btn-danger btn-sm" onclick="this.closest('tr').remove()">X</button></td>
                        </tr>
                    }
                </tbody>
            </table>
            <button type="submit" class="btn btn-primary px-5 rounded-pill">حفظ التعديلات وتحديث المخزن</button>
            <a asp-action="Index" class="btn btn-light rounded-pill">إلغاء</a>
        </form>
    </div>
</body>
</html>