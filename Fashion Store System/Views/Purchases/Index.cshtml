@model IEnumerable<Fashion_Store_System.Models.PurchaseInvoice>
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.rtl.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        body {
            background: #F8EDED;
            padding: 20px;
            font-family: 'Segoe UI';
        }

        .main-card {
            background: white;
            border-radius: 15px;
            padding: 20px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.05);
        }
    </style>
</head>
<body>
    <div class="container mt-4">
        <div class="d-flex justify-content-between mb-4">
            <h2 class="fw-bold">سجل فواتير المشتريات</h2>
            <a asp-action="Create" class="btn btn-dark rounded-pill px-4">فاتورة جديدة</a>
        </div>

        <div class="main-card">
            <table class="table table-hover text-center">
                <thead class="table-light">
                    <tr>
                        <th>رقم الفاتورة</th>
                        <th>التاريخ</th>
                        <th>المورد</th>
                        <th>الإجمالي</th>
                        <th>العمليات</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td>@item.InvoiceDate.ToShortDateString()</td>
                            <td>@item.Supplier?.Name</td>
                            <td class="fw-bold text-success">@item.TotalAmount.ToString("N0") ج.م</td>
                            <td>
                                
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary"><i class="bi bi-pencil"></i></a>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary" style="color: var(--side-bg); border-color: var(--dusty-accent);" title="تفاصيل"><i class="bi bi-eye-fill"></i></a>

                                <button onclick="confirmDelete(@item.Id)" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function confirmDelete(id) {
            Swal.fire({ title: 'حذف الفاتورة؟', text: "سيتم خصم الكميات من المخزن!", icon: 'warning', showCancelButton: true, confirmButtonText: 'نعم، احذف' })
            .then((result) => { if (result.isConfirmed) $.post('/Purchases/Delete/' + id, () => location.reload()); });
        }
    </script>
</body>
</html>