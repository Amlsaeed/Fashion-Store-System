@model Fashion_Store_System.Models.PurchaseInvoice

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <title>تفاصيل الفاتورة #@Model.Id</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.rtl.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        :root {
            --main-bg: #F8EDED;
            --dark-text: #40415A;
        }

        body {
            background-color: var(--main-bg);
            font-family: 'Segoe UI', sans-serif;
            padding: 40px;
        }

        .invoice-box {
            background: white;
            border-radius: 20px;
            padding: 40px;
            shadow: 0 10px 30px rgba(0,0,0,0.08);
            position: relative;
            overflow: hidden;
        }

        .invoice-header {
            border-bottom: 2px solid #eee;
            padding-bottom: 20px;
            margin-bottom: 30px;
        }

        .badge-status {
            background-color: #e3f2fd;
            color: #0d47a1;
            padding: 8px 15px;
            border-radius: 10px;
            font-weight: bold;
        }

        .table thead {
            background-color: #f8f9fa;
        }

        .total-section {
            background-color: #fcfcfc;
            border-radius: 15px;
            padding: 20px;
            margin-top: 20px;
            border: 1px solid #eee;
        }

        @@media print {
            .no-print {
                display: none;
            }

            body {
                padding: 0;
                background: white;
            }

            .invoice-box {
                box-shadow: none;
                border: none;
            }
        }
    </style>
</head>
<body>

    <div class="container">
        <div class="invoice-box shadow">
            <div class="d-flex justify-content-between mb-4 no-print">
                <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
                    <i class="bi bi-arrow-right me-1"></i> العودة للسجل
                </a>
                <div>
                    <button onclick="window.print()" class="btn btn-dark rounded-pill px-4">
                        <i class="bi bi-printer me-1"></i> طباعة الفاتورة
                    </button>
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary rounded-pill px-4">
                        <i class="bi bi-pencil-square me-1"></i> تعديل
                    </a>
                </div>
            </div>

            <div class="invoice-header d-flex justify-content-between align-items-center">
                <div>
                    <h1 class="fw-bold mb-1" style="color: var(--dark-text);">فاتورة مشتريات</h1>
                    <p class="text-muted">رقم المرجع: #INV-@Model.Id</p>
                </div>
                <div class="text-end">
                    <h4 class="fw-bold">Fashion Store</h4>
                    <p class="text-muted mb-0">تاريخ الفاتورة: @Model.InvoiceDate.ToString("yyyy/MM/dd")</p>
                    <p class="text-muted">توقيت التسجيل: @Model.InvoiceDate.ToString("hh:mm tt")</p>
                </div>
            </div>

            <div class="row mb-5">
                <div class="col-6">
                    <h6 class="text-muted text-uppercase fw-bold small mb-3">بيانات المورد</h6>
                    <h5 class="fw-bold">@Model.Supplier?.Name</h5>
                    <p class="text-muted mb-1"><i class="bi bi-telephone me-2"></i> @Model.Supplier?.Phone</p>
                    <p class="text-muted"><i class="bi bi-geo-alt me-2"></i> @Model.Supplier?.Address</p>
                </div>
                <div class="col-6 text-end">
                    <h6 class="text-muted text-uppercase fw-bold small mb-3">حالة العملية</h6>
                    <span class="badge-status"><i class="bi bi-check-circle-fill me-1"></i> تم تحديث المخزن</span>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th class="py-3">الصنف / المنتج</th>
                            <th class="py-3 text-center">الكمية المضافة</th>
                            <th class="py-3 text-center">سعر التكلفة</th>
                            <th class="py-3 text-end">الإجمالي</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.PurchaseItems)
                        {
                            <tr>
                                <td class="py-3">
                                    <span class="fw-bold text-dark">@item.Product?.Name</span>
                                </td>
                                <td class="text-center">@item.Quantity</td>
                                <td class="text-center">@item.UnitPrice.ToString("N2") ج.م</td>
                                <td class="text-end fw-bold">@((item.Quantity * item.UnitPrice).ToString("N2")) ج.م</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="row mt-4">
                <div class="col-md-7">
                    <div class="p-3 border-start border-4" style="background: #fcfcfc;">
                        <h6 class="fw-bold mb-2">ملاحظات:</h6>
                        <p class="text-muted mb-0">@(string.IsNullOrEmpty(Model.Notes) ? "لا توجد ملاحظات على هذه الفاتورة." : Model.Notes)</p>
                    </div>
                </div>
                <div class="col-md-5">
                    <div class="total-section">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">إجمالي الأصناف:</span>
                            <span>@Model.PurchaseItems.Count صنف</span>
                        </div>
                        <div class="d-flex justify-content-between mb-3">
                            <span class="text-muted">إجمالي القطع:</span>
                            <span>@Model.PurchaseItems.Sum(x => x.Quantity) قطعة</span>
                        </div>
                        <hr>
                        <div class="d-flex justify-content-between align-items-center">
                            <h5 class="fw-bold mb-0">المبلغ الإجمالي:</h5>
                            <h4 class="fw-bold text-success mb-0">@Model.TotalAmount.ToString("N0") ج.م</h4>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

</body>
</html>