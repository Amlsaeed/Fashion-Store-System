@model Fashion_Store_System.Models.Supplier
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.rtl.min.css">
    <style>
        body {
            background: #F8EDED;
            padding: 50px;
        }

        .form-card {
            background: white;
            border-radius: 25px;
            padding: 40px;
            max-width: 600px;
            margin: auto;
            box-shadow: 0 15px 35px rgba(0,0,0,0.1);
        }

        .btn-update {
            background: #27ae60;
            color: white;
            border-radius: 50px;
            width: 100%;
            padding: 12px;
            font-weight: bold;
            border: none;
        }
    </style>
</head>
<body>
    <div class="form-card">
        <h3 class="text-center fw-bold mb-4" style="color: #40415A;">تعديل بيانات المورد</h3>
        <form asp-action="Edit">
            <input type="hidden" asp-for="Id" />
            <div class="mb-3">
                <label class="form-label fw-bold">الاسم</label>
                <input asp-for="Name" class="form-control" />
            </div>
            <div class="mb-3">
                <label class="form-label fw-bold">رقم الهاتف</label>
                <input asp-for="Phone" class="form-control" />
            </div>
            <div class="mb-3">
                <label class="form-label fw-bold">العنوان</label>
                <textarea asp-for="Address" class="form-control" rows="2"></textarea>
            </div>
            <button type="submit" class="btn btn-update shadow mt-3">حفظ التغييرات</button>
            <a asp-action="Index" class="btn btn-link w-100 mt-2 text-decoration-none text-muted">إلغاء</a>
        </form>
    </div>
</body>
</html>