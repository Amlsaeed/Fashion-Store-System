@model Fashion_Store_System.Models.Supplier
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.rtl.min.css">
</head>
<body style="background: #F8EDED; padding: 50px;">
    <div class="card shadow border-0 mx-auto" style="max-width: 600px; border-radius: 20px;">
        <div class="card-body p-5">
            <h2 class="fw-bold mb-4">بيانات المورد</h2>
            <hr>
            <div class="mb-4">
                <label class="text-muted d-block small">اسم المورد</label>
                <h4 class="fw-bold text-dark">@Model.Name</h4>
            </div>
            <div class="mb-4">
                <label class="text-muted d-block small">رقم الهاتف</label>
                <h5 class="text-primary">@Model.Phone</h5>
            </div>
            <div class="mb-4">
                <label class="text-muted d-block small">العنوان</label>
                <p class="fs-5">@Model.Address</p>
            </div>
            <div class="d-flex gap-2">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-dark rounded-pill px-4">تعديل</a>
                <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">رجوع</a>
            </div>
        </div>
    </div>
</body>
</html>
