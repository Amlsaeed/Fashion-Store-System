@model Fashion_Store_System.Models.SalesInvoice
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.rtl.min.css">
    <style>
        body {
            background: #E7F0DC;
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100vh;
        }

        .delete-box {
            background: white;
            padding: 40px;
            border-radius: 20px;
            text-align: center;
            max-width: 500px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        }
    </style>
</head>
<body>
    <div class="delete-box border-top border-danger border-5">
        <div class="text-danger mb-4"><i class="bi bi-exclamation-triangle-fill" style="font-size: 3rem;"></i></div>
        <h3 class="fw-bold">تأكيد حذف الفاتورة؟</h3>
        <p class="text-muted">حذف الفاتورة رقم <strong>#@Model.Id</strong> سيؤدي إلى إرجاع البضاعة للمخزن مرة أخرى.</p>

        <div class="bg-light p-3 rounded mb-4 text-end">
            <p class="mb-1 small text-muted">العميل: @Model.CustomerName</p>
            <p class="mb-0 fw-bold">المبلغ: @Model.TotalAmount.ToString("N0") ج.م</p>
        </div>

        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger rounded-pill px-4">نعم، حذف الفاتورة</button>
            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 ms-2">إلغاء</a>
        </form>
    </div>
</body>
</html>
