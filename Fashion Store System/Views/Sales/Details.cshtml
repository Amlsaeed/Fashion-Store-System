@model Fashion_Store_System.Models.SalesInvoice
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.rtl.min.css">
    <style>
        body {
            background: #E7F0DC;
            padding: 40px;
        }

        .invoice-box {
            background: white;
            border-radius: 15px;
            padding: 40px;
            border-top: 10px solid #2D5A27;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="invoice-box shadow">
            <div class="d-flex justify-content-between mb-5">
                <div>
                    <h2 class="fw-bold">FASHION STORE</h2>
                    <p class="text-muted">فاتورة مبيعات رقم #@Model.Id</p>
                </div>
                <div class="text-end">
                    <h5>العميل: @(Model.CustomerName ?? "عميل نقدي")</h5>
                    <p>التاريخ: @Model.SalesDate.ToShortDateString()</p>
                </div>
            </div>

            <table class="table table-bordered">
                <thead class="table-dark">
                    <tr>
                        <th>المنتج</th>
                        <th>الكمية</th>
                        <th>السعر</th>
                        <th>الإجمالي</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.SalesItems)
                    {
                        <tr>
                            <td>@item.Product?.Name</td>
                            <td>@item.Quantity</td>
                            <td>@item.UnitPrice.ToString("N2")</td>
                            <td>@((item.Quantity * item.UnitPrice).ToString("N2")) ج.م</td>
                        </tr>
                    }
                </tbody>
            </table>

            <div class="text-end mt-4">
                <h4 class="fw-bold text-success">الإجمالي النهائي: @Model.TotalAmount.ToString("N2") ج.م</h4>
            </div>

            <div class="mt-5 no-print">
                <button onclick="window.print()" class="btn btn-dark px-4 rounded-pill">طباعة الفاتورة</button>
                <a asp-action="Index" class="btn btn-light px-4 rounded-pill">رجوع</a>
            </div>
        </div>
    </div>
</body>
</html>