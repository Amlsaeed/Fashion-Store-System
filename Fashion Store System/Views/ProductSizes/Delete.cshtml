@model Fashion_Store_System.Models.ProductSize

@{
    ViewData["Title"] = "حذف المقاس";
    Layout = "_AdminLayout";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-lg animate__animated animate__headShake" style="border-radius: 25px; overflow: hidden;">

                <div class="card-header bg-danger text-white text-center py-5 border-0">
                    <i class="bi bi-exclamation-octagon-fill display-1"></i>
                    <h2 class="fw-bold mt-3">هل أنت متأكد؟</h2>
                    <p class="mb-0 opacity-75 fs-5">أنت على وشك حذف بيانات هذا المقاس نهائياً</p>
                </div>

                <div class="card-body p-5 text-center">
                    <p class="text-muted mb-4">سيتم إزالة المقاس التالي من قاعدة البيانات، ويرجى العلم أن هذا قد يؤثر على المنتجات المرتبطة به:</p>

                    <div class="display-value mb-5 p-4 bg-light rounded-4 border">
                        <span class="text-muted d-block small text-uppercase mb-2">اسم المقاس المراد حذفه</span>
                        <span class="fs-2 fw-bold text-danger">@Html.DisplayFor(model => model.Name)</span>
                    </div>

                    <form asp-action="Delete">
                        <input type="hidden" asp-for="Id" />

                        <div class="d-grid gap-3 d-sm-flex justify-content-center">
                            <button type="submit" class="btn btn-danger btn-lg rounded-pill px-5 shadow-sm fw-bold">
                                <i class="bi bi-trash3 me-2"></i> نعم، تأكيد الحذف
                            </button>

                            <a asp-action="Index" class="btn btn-light btn-lg rounded-pill px-5 border fw-bold text-muted">
                                <i class="bi bi-x-lg me-1"></i> تراجع وإلغاء
                            </a>
                        </div>
                    </form>
                </div>

                <div class="card-footer bg-light border-0 py-3 text-center">
                    <small class="text-muted"><i class="bi bi-shield-lock me-1"></i> الإجراءات المحمية بواسطة نظام الإدارة</small>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* تحسين شكل الزوايا */
    .rounded-4 {
        border-radius: 20px !important;
    }

    /* حركة اهتزاز خفيفة عند فتح الصفحة لجذب الانتباه (تحتاج مكتبة Animate.css) */
    .animate__headShake {
        animation-duration: 1.5s;
    }

    /* تحسين مظهر الزرار عند التمرير */
    .btn-danger:hover {
        background-color: #dc3545;
        transform: scale(1.05);
        transition: all 0.3s ease;
    }
</style>