@model Fashion_Store_System.Models.ProductSize

@{
    ViewData["Title"] = "تفاصيل المقاس";
    Layout = "_AdminLayout";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0" style="border-radius: 20px; overflow: hidden;">
                <div class="card-header bg-light py-4 border-0 text-center">
                    <div class="icon-circle bg-warning text-white mb-3 shadow-sm d-inline-flex align-items-center justify-content-center" style="width: 70px; height: 70px; border-radius: 50%;">
                        <i class="bi bi-info-lg fs-2"></i>
                    </div>
                    <h3 class="fw-bold text-dark">تفاصيل المقاس</h3>
                    <p class="text-muted mb-0">عرض البيانات المسجلة لهذا المقاس</p>
                </div>

                <div class="card-body p-4">
                    <div class="info-group mb-4 p-3 bg-light rounded-4 border-start border-warning border-4">
                        <div class="row align-items-center">
                            <div class="col-sm-4">
                                <span class="text-muted small text-uppercase fw-bold">اسم المقاس:</span>
                            </div>
                            <div class="col-sm-8">
                                <span class="fs-4 fw-bold text-primary">@Html.DisplayFor(model => model.Name)</span>
                            </div>
                        </div>
                    </div>

                    <div class="info-group mb-4 p-3 bg-light rounded-4">
                        <div class="row align-items-center">
                            <div class="col-sm-4">
                                <span class="text-muted small text-uppercase fw-bold">الرقم التعريفي (ID):</span>
                            </div>
                            <div class="col-sm-8">
                                <span class="badge bg-secondary">#@Model?.Id</span>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mt-5">
                        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
                            <i class="bi bi-arrow-right-short"></i> العودة للقائمة
                        </a>
                        <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-primary rounded-pill px-4 shadow">
                            <i class="bi bi-pencil-square me-1"></i> تعديل البيانات
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* لمسة جمالية إضافية */
    .rounded-4 {
        border-radius: 15px !important;
    }

    .card {
        transition: transform 0.3s ease;
    }

        .card:hover {
            transform: translateY(-5px);
        }
</style>