@model IEnumerable<Fashion_Store_System.Models.Category>

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>إدارة الفئات</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.rtl.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

    <style>
        :root {
            --side-bg: #40415A; /* الرمادي المزرق من الصورة */
            --pale-bg: #F8EDED; /* البيج الوردي من الصورة */
            --dusty-accent: #E8D3D3; /* الوردي البودرة للمسات */
        }

        body {
            background-color: var(--pale-bg); /* تغيير خلفية الموقع للبيج */
            font-family: 'Segoe UI', sans-serif;
        }

        .main-container {
            margin-top: 40px;
            margin-bottom: 40px;
        }

        .table-card {
            background: white;
            border-radius: 20px;
            padding: 30px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
            border: none;
        }

        th, td {
            text-align: center !important;
            vertical-align: middle !important;
            padding: 15px !important;
        }

        thead th {
            background-color: #fafafa !important;
            color: var(--side-bg); /* تغيير لون عناوين الجدول */
            font-weight: 700;
            border-bottom: 2px solid var(--dusty-accent) !important; /* تغيير لون الخط الفاصل للوردي */
        }

        .dataTables_filter {
            float: none !important;
            text-align: center !important;
            margin-bottom: 30px;
        }

            .dataTables_filter input {
                width: 50% !important;
                display: inline-block;
                border-radius: 50px !important;
                padding: 12px 25px !important;
                border: 2px solid var(--dusty-accent) !important; /* لون البرواز للبحث */
                transition: 0.3s;
                outline: none;
            }

                .dataTables_filter input:focus {
                    border-color: var(--side-bg) !important; /* لون البرواز عند الضغط */
                    box-shadow: 0 0 10px rgba(64, 65, 90, 0.1);
                }

        .btn-add {
            background-color: var(--side-bg); /* لون زر الإضافة */
            border-color: var(--side-bg);
            color: white;
            border-radius: 50px;
            padding: 10px 25px;
            font-weight: 600;
        }

            .btn-add:hover {
                background-color: #313244;
                border-color: #313244;
                color: white;
            }

        .badge-status {
            border-radius: 6px;
            padding: 6px 12px;
        }

        /* تنسيق أزرار الترقيم Pagination */
        .page-item.active .page-link {
            background-color: var(--side-bg) !important;
            border-color: var(--side-bg) !important;
        }

        .page-link {
            color: var(--side-bg);
        }
    </style>
</head>
<body>

    <div class="container main-container">
        <div class="d-flex justify-content-between align-items-center mb-5">
            <h2 class="fw-bold m-0" style="color: var(--side-bg);"> الأقسام</h2>
            <a asp-action="Create" class="btn btn-add shadow-sm">
                <i class="bi bi-plus-lg"></i> إضافة قسم جديد
            </a>
        </div>

        <div class="table-card">
            <table id="categoriesTable" class="table table-hover">
                <thead>
                    <tr>
                        <th style="width: 10%">المعرف</th>
                        <th style="width: 25%">اسم الفئة</th>
                        <th style="width: 15%">الصورة</th>
                        <th style="width: 15%">الحالة</th>
                        <th style="width: 15%">تاريخ الإنشاء</th>
                        <th style="width: 20%">العمليات</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><span class="text-muted fw-bold">#@item.Id</span></td>
                            <td><span class="fw-bold text-dark">@item.Name</span></td>
                            <td>
                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                {
                                    <img src="@item.ImageUrl" class="rounded shadow-sm" width="50" height="50" style="object-fit: cover; border: 1px solid var(--dusty-accent);">
                                }
                                else
                                {
                                    <small class="text-muted italic">لا يوجد</small>
                                }
                            </td>
                            <td>
                                <span class="badge badge-status @(item.IsActive ? "bg-success-subtle text-success border border-success" : "bg-danger-subtle text-danger border border-danger")">
                                    @(item.IsActive ? "نشط" : "غير نشط")
                                </span>
                            </td>
                            <td>@item.CreatedAt.ToString("yyyy-MM-dd")</td>
                            <td>
                                <div class="d-flex justify-content-center gap-2">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary" style="color: var(--side-bg); border-color: var(--dusty-accent);" title="تعديل"><i class="bi bi-pencil-fill"></i></a>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary" style="color: var(--side-bg); border-color: var(--dusty-accent);" title="تفاصيل"><i class="bi bi-eye-fill"></i></a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" title="حذف"><i class="bi bi-trash3-fill"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>

    <script>
        $(document).ready(function () {
            $('#categoriesTable').DataTable({
                "pageLength": 10,
                "lengthChange": false, // إخفاء قائمة تغيير العدد ليبقى الشكل ثابتاً
                "dom": '<"top"f>rt<"bottom"p><"clear">',
                "language": {
                    "search": "",
                    "searchPlaceholder": "إبحث عن قسم هنا...",
                    "paginate": {
                        "next": "التالي",
                        "previous": "السابق"
                    },
                    "info": "عرض صفحة _PAGE_ من _PAGES_"
                }
            });

            $('.dataTables_filter').addClass('d-flex justify-content-center w-100');
        });
    </script>

</body>
</html>