@model Fashion_Store_System.Models.Category

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <title>تأكيد الحذف</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.rtl.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

    <style>
        :root {
            --side-bg: #40415A; /* الرمادي المزرق */
            --pale-bg: #F8EDED; /* البيج الوردي */
            --danger-red: #d9534f;
        }

        body {
            background-color: var(--pale-bg);
            font-family: 'Segoe UI', sans-serif;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            margin: 0;
        }

        .delete-card {
            background: white;
            border-radius: 30px;
            padding: 40px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.1);
            width: 100%;
            max-width: 500px;
            text-align: center;
            border: none;
        }

        .warning-icon {
            font-size: 4rem;
            color: var(--danger-red);
            margin-bottom: 20px;
            animation: pulse 2s infinite;
        }

        h3 {
            color: var(--side-bg);
            font-weight: 700;
            margin-bottom: 15px;
        }

        .category-name {
            background-color: #fdf2f2;
            color: var(--danger-red);
            padding: 10px 20px;
            border-radius: 12px;
            display: inline-block;
            font-weight: 700;
            margin-bottom: 25px;
            border: 1px solid #fee2e2;
        }

        .btn-delete-confirm {
            background-color: var(--danger-red);
            color: white;
            border-radius: 50px;
            padding: 12px 30px;
            font-weight: 600;
            border: none;
            transition: 0.3s;
            width: 100%;
            margin-bottom: 10px;
        }

            .btn-delete-confirm:hover {
                background-color: #c9302c;
                transform: scale(1.02);
            }

        .btn-cancel {
            background-color: transparent;
            color: #888;
            border-radius: 50px;
            padding: 12px 30px;
            font-weight: 600;
            border: 2px solid #eee;
            text-decoration: none;
            display: block;
            width: 100%;
            transition: 0.3s;
        }

            .btn-cancel:hover {
                background-color: #f8f8f8;
                color: #555;
            }

        @@keyframes pulse {
            0% {
                transform: scale(1);
            }

            50% {
                transform: scale(1.1);
            }

            100% {
                transform: scale(1);
            }
        }
    </style>
</head>
<body>

    <div class="delete-card shadow">
        <div class="warning-icon">
            <i class="bi bi-exclamation-octagon-fill"></i>
        </div>

        <h3>تأكيد الحذف نهائياً</h3>
        <p class="text-muted">أنت على وشك حذف قسم:</p>

        <div class="category-name">
            @Model.Name
        </div>

        <div class="alert alert-warning small mb-4">
            <i class="bi bi-info-circle me-1"></i>
            انتبه: سيتم حذف جميع البيانات المرتبطة بهذا القسم ولا يمكن التراجع.
        </div>

        <form id="deleteForm" asp-action="Delete">
            <input type="hidden" asp-for="Id" />

            <button type="button" id="btnConfirm" class="btn-delete-confirm shadow-sm">
                <i class="bi bi-trash3 me-2"></i> تأكيد الحذف الآن
            </button>

            <a asp-action="Index" class="btn btn-cancel">
                إلغاء والعودة للقائمة
            </a>
        </form>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        $('#btnConfirm').on('click', function () {
            Swal.fire({
                title: 'هل أنت متأكد فعلاً؟',
                text: "لن تستطيع استعادة بيانات قسم (@Model.Name) مرة أخرى!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#40415A',
                confirmButtonText: 'نعم، احذف نهائياً',
                cancelButtonText: 'تراجع عن الحذف',
                reverseButtons: true
            }).then((result) => {
                if (result.isConfirmed) {
                    // لو وافق، نطلع رسالة نجاح لحظية وبعدها نبعت الفورم
                    Swal.fire({
                        title: 'تم الحذف!',
                        text: 'جاري تحديث البيانات...',
                        icon: 'success',
                        showConfirmButton: false,
                        timer: 1500
                    }).then(() => {
                        $('#deleteForm').submit();
                    });
                }
            });
        });
    </script>

    @if (TempData["DeleteMessage"] != null)
    {
        <script>
            Swal.fire({
                title: 'نجحت العملية',
                text: '@TempData["DeleteMessage"]',
                icon: 'success',
                confirmButtonColor: '#40415A'
            });
        </script>
    }

</body>
</html>