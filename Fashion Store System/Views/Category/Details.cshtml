@model Fashion_Store_System.ViewModels.CategoryVM.CategoryVMDt

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <title>تفاصيل القسم</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.rtl.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

    <style>
        :root {
            --side-bg: #40415A; /* الرمادي المزرق */
            --pale-bg: #F8EDED; /* البيج الوردي */
            --dusty-accent: #E8D3D3; /* الوردي البودرة */
        }

        body {
            background-color: var(--pale-bg);
            font-family: 'Segoe UI', sans-serif;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            margin: 0;
        }

        .details-card {
            background: white;
            border-radius: 30px;
            overflow: hidden;
            box-shadow: 0 20px 40px rgba(0,0,0,0.08);
            width: 100%;
            max-width: 800px;
            border: none;
            animation: slideUp 0.5s ease;
        }

        /* الجزء العلوي الملون */
        .details-header {
            background-color: var(--side-bg);
            padding: 30px;
            color: white;
            text-align: center;
        }

        .category-img {
            width: 180px;
            height: 180px;
            object-fit: cover;
            border-radius: 20px;
            border: 5px solid white;
            box-shadow: 0 10px 20px rgba(0,0,0,0.1);
            margin-top: -90px; /* حركة تداخل الصورة مع الهيدر */
            background-color: white;
        }

        .info-section {
            padding: 100px 40px 40px; /* تباعد كبير من فوق عشان الصورة */
        }

        .info-row {
            display: flex;
            justify-content: space-between;
            padding: 15px 0;
            border-bottom: 1px solid #f5f5f5;
        }

        .info-label {
            color: #888;
            font-weight: 600;
        }

        .info-value {
            color: var(--side-bg);
            font-weight: 700;
        }

        .status-badge {
            padding: 5px 15px;
            border-radius: 50px;
            font-size: 0.85rem;
        }

        .btn-action {
            border-radius: 50px;
            padding: 12px 35px;
            font-weight: 600;
            transition: 0.3s;
        }

        .btn-edit-main {
            background-color: var(--side-bg);
            color: white;
            border: none;
        }

            .btn-edit-main:hover {
                background-color: #313244;
                color: white;
                transform: translateY(-2px);
            }

        @@keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
</head>
<body>

    <div class="details-card">
        <div class="details-header">
            <h3 class="m-0 fw-bold"><i class="bi bi-info-circle me-2"></i> تفاصيل فئة @Model.Name</h3>
        </div>

        <div class="text-center">
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <img src="@Model.ImageUrl" class="category-img" alt="صورة الفئة" />
            }
            else
            {
                <div class="category-img d-flex align-items-center justify-content-center bg-light">
                    <i class="bi bi-image text-muted" style="font-size: 3rem;"></i>
                </div>
            }
        </div>

        <div class="info-section">
            <div class="row g-4">
                <div class="col-md-6">
                    <div class="info-row">
                        <span class="info-label">المعرف الرقمي</span>
                        <span class="info-value">#@Model.Id</span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="info-row">
                        <span class="info-label">اسم القسم</span>
                        <span class="info-value">@Model.Name</span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="info-row">
                        <span class="info-label">حالة القسم</span>
                        <span>
                            @if (Model.IsActive)
                            {
                                <span class="status-badge bg-success-subtle text-success border border-success">نشط الآن</span>
                            }
                            else
                            {
                                <span class="status-badge bg-danger-subtle text-danger border border-danger">غير نشط</span>
                            }
                        </span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="info-row">
                        <span class="info-label">تاريخ الإنشاء</span>
                        <span class="info-value">@Model.CreatedAt.ToString("dd MMMM yyyy")</span>
                    </div>
                </div>
            </div>

            <div class="d-flex justify-content-center gap-3 mt-5">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-action btn-edit-main shadow-sm">
                    <i class="bi bi-pencil-square me-2"></i> تعديل البيانات
                </a>
                <a asp-action="Index" class="btn btn-action btn-outline-secondary text-muted">
                    <i class="bi bi-arrow-right me-2"></i> العودة للقائمة
                </a>
            </div>
        </div>
    </div>

</body>
</html>