@model Fashion_Store_System.Models.ProductColor

@{
    ViewData["Title"] = "حذف مقاس";
    Layout = "_AdminLayout";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-lg" style="border-radius: 25px;">
                <div class="card-body p-5 text-center">
                    <div class="text-danger mb-4">
                        <i class="bi bi-exclamation-triangle-fill" style="font-size: 5rem;"></i>
                    </div>
                    <h2 class="fw-bold text-dark">هل أنت متأكد؟</h2>
                    <p class="text-muted fs-5 mb-4">
                        أنت على وشك حذف المقاس <span class="text-danger fw-bold">"@Model.Name"</span> نهائياً من النظام. لا يمكن التراجع عن هذا الإجراء!
                    </p>

                    <form asp-action="Delete">
                        <input type="hidden" asp-for="Id" />

                        <div class="d-flex justify-content-center gap-3 mt-4">
                            <button type="submit" class="btn btn-danger btn-lg px-5 rounded-pill shadow">
                                <i class="bi bi-trash3 me-1"></i> نعم، احذفه
                            </button>
                            <a asp-action="Index" class="btn btn-light btn-lg px-5 rounded-pill border">
                                تراجع
                            </a>
                        </div>
                    </form>
                </div>
                <div class="card-footer bg-light border-0 py-3 text-center" style="border-radius: 0 0 25px 25px;">
                    <small class="text-muted">سيتم إزالة هذا المقاس من جميع المنتجات المرتبطة به.</small>
                </div>
            </div>
        </div>
    </div>
</div>