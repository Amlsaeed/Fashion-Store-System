@model Fashion_Store_System.Models.ProductColor

@{
    ViewData["Title"] = "إضافة لون";
    Layout = "_AdminLayout";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow border-0" style="border-radius: 25px; overflow: hidden;">
                <div class="card-header bg-dark text-white text-center py-4">
                    <i class="bi bi-plus-circle fs-1"></i>
                    <h3 class="mt-2 fw-bold">إضافة لون جديد</h3>
                    <p class="mb-0 opacity-75">أضف لمسة جمالية جديدة لمنتجاتك</p>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="form-floating mb-4">
                            <input asp-for="Name" class="form-control rounded-pill px-4" id="colorName" placeholder="مثلاً: أحمر ملكي" style="border: 2px solid #eee;" />
                            <label for="colorName" class="ms-3 text-muted">اسم اللون</label>
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg rounded-pill shadow">
                                <i class="bi bi-save me-1"></i> حفظ اللون
                            </button>
                            <a asp-action="Index" class="btn btn-light btn-sm rounded-pill text-muted mt-2">
                                إلغاء والعودة للقائمة
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>